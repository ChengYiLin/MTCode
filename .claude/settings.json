{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; case \"$f\" in *.ts|*.tsx) pnpm exec prettier --write \"$f\" ;; esac; } 2>/dev/null || true",
            "statusMessage": "Formatting with Prettier"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/validate-post-date.sh",
            "statusMessage": "Validating post frontmatter"
          }
        ]
      }
    ]
  }
}
